@model RegisterTraineeViewModel
@{
    ViewData["Title"] = "Register Trainee";
}

<div class="mb-4">
    <a asp-action="Index" class="text-muted small text-decoration-none">
        <i class="bi bi-arrow-left me-1"></i> Back to Trainees
    </a>
    <h4 class="fw-bold mt-1 mb-0">Register New Trainee</h4>
</div>

<div class="card border-0 shadow-sm" style="max-width: 760px;">
    <div class="card-body p-4">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger small py-2 mb-3"></div>

            <h6 class="fw-semibold text-uppercase text-muted small mb-3">Personal Information</h6>
            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label asp-for="FirstName" class="form-label fw-semibold small"></label>
                    <input asp-for="FirstName" class="form-control" />
                    <span asp-validation-for="FirstName" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="LastName" class="form-label fw-semibold small"></label>
                    <input asp-for="LastName" class="form-control" />
                    <span asp-validation-for="LastName" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Email" class="form-label fw-semibold small"></label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Phone" class="form-label fw-semibold small"></label>
                    <input asp-for="Phone" class="form-control" />
                    <span asp-validation-for="Phone" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="NationalId" class="form-label fw-semibold small"></label>
                    <input asp-for="NationalId" class="form-control" />
                    <span asp-validation-for="NationalId" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="DateOfBirth" class="form-label fw-semibold small"></label>
                    <input asp-for="DateOfBirth" class="form-control" type="date" />
                    <span asp-validation-for="DateOfBirth" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="Gender" class="form-label fw-semibold small"></label>
                    <select asp-for="Gender" class="form-select"
                            asp-items="Html.GetEnumSelectList<GymManagement.Domain.Enums.Gender>()"></select>
                </div>
                <div class="col-12">
                    <label asp-for="Address" class="form-label fw-semibold small"></label>
                    <input asp-for="Address" class="form-control" />
                </div>
            </div>

            <h6 class="fw-semibold text-uppercase text-muted small mb-3">Physical Stats (Optional)</h6>
            <div class="row g-3 mb-4">
                <div class="col-md-3">
                    <label asp-for="HeightCm" class="form-label fw-semibold small"></label>
                    <input asp-for="HeightCm" class="form-control" placeholder="e.g. 175" />
                    <span asp-validation-for="HeightCm" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="WeightKg" class="form-label fw-semibold small"></label>
                    <input asp-for="WeightKg" class="form-control" placeholder="e.g. 80" />
                    <span asp-validation-for="WeightKg" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="MedicalNotes" class="form-label fw-semibold small"></label>
                    <textarea asp-for="MedicalNotes" class="form-control" rows="2"
                              placeholder="Any injuries, allergies, or conditions…"></textarea>
                </div>
            </div>

            <h6 class="fw-semibold text-uppercase text-muted small mb-3">Emergency Contact</h6>
            <div class="row g-3 mb-4">
                <div class="col-md-5">
                    <label asp-for="EmergencyContactName" class="form-label fw-semibold small"></label>
                    <input asp-for="EmergencyContactName" class="form-control" />
                    <span asp-validation-for="EmergencyContactName" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="EmergencyContactPhone" class="form-label fw-semibold small"></label>
                    <input asp-for="EmergencyContactPhone" class="form-control" />
                    <span asp-validation-for="EmergencyContactPhone" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="EmergencyContactRelation" class="form-label fw-semibold small"></label>
                    <input asp-for="EmergencyContactRelation" class="form-control" placeholder="e.g. Spouse" />
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-dark px-4">
                    <i class="bi bi-person-plus me-1"></i> Register Trainee
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
