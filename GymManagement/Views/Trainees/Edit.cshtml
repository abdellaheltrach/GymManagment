@model EditTraineeViewModel
@{
    ViewData["Title"] = "Edit Trainee";
}

<div class="mb-4">
    <a asp-action="Details" asp-route-id="@Model.TraineeId"
       class="text-muted small text-decoration-none">
        <i class="bi bi-arrow-left me-1"></i> Back to Profile
    </a>
    <h4 class="fw-bold mt-1 mb-0">Edit Trainee</h4>
</div>

<div class="card border-0 shadow-sm" style="max-width: 760px;">
    <div class="card-body p-4">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="TraineeId" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger small py-2 mb-3"></div>

            <h6 class="fw-semibold text-uppercase text-muted small mb-3">Personal Information</h6>
            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label asp-for="FirstName" class="form-label fw-semibold small"></label>
                    <input asp-for="FirstName" class="form-control" />
                    <span asp-validation-for="FirstName" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="LastName" class="form-label fw-semibold small"></label>
                    <input asp-for="LastName" class="form-control" />
                    <span asp-validation-for="LastName" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Email" class="form-label fw-semibold small"></label>
                    <input asp-for="Email" class="form-control" readonly />
                    <div class="form-text">Email cannot be changed here.</div>
                </div>
                <div class="col-md-6">
                    <label asp-for="Phone" class="form-label fw-semibold small"></label>
                    <input asp-for="Phone" class="form-control" />
                    <span asp-validation-for="Phone" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="Address" class="form-label fw-semibold small"></label>
                    <input asp-for="Address" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="HeightCm" class="form-label fw-semibold small"></label>
                    <input asp-for="HeightCm" class="form-control" />
                    <span asp-validation-for="HeightCm" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="WeightKg" class="form-label fw-semibold small"></label>
                    <input asp-for="WeightKg" class="form-control" />
                    <span asp-validation-for="WeightKg" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="MedicalNotes" class="form-label fw-semibold small"></label>
                    <textarea asp-for="MedicalNotes" class="form-control" rows="2"></textarea>
                </div>
            </div>

            <h6 class="fw-semibold text-uppercase text-muted small mb-3">Emergency Contact</h6>
            <div class="row g-3 mb-4">
                <div class="col-md-5">
                    <label asp-for="EmergencyContactName" class="form-label fw-semibold small"></label>
                    <input asp-for="EmergencyContactName" class="form-control" />
                    <span asp-validation-for="EmergencyContactName" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="EmergencyContactPhone" class="form-label fw-semibold small"></label>
                    <input asp-for="EmergencyContactPhone" class="form-control" />
                    <span asp-validation-for="EmergencyContactPhone" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="EmergencyContactRelation" class="form-label fw-semibold small"></label>
                    <input asp-for="EmergencyContactRelation" class="form-control" />
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-dark px-4">
                    <i class="bi bi-floppy me-1"></i> Save Changes
                </button>
                <a asp-action="Details" asp-route-id="@Model.TraineeId"
                   class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
