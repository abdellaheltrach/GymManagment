@model TraineeDetailViewModel
@{
    ViewData["Title"] = Model.Trainee.FirstName + " " + Model.Trainee.LastName;
    var t = Model.Trainee;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <a asp-action="Index" class="text-muted small text-decoration-none">
            <i class="bi bi-arrow-left me-1"></i> Back to Trainees
        </a>
        <h4 class="fw-bold mb-0 mt-1">@t.FirstName + @t.LastName</h4>
    </div>
    @if (User.IsInRole("Admin") || User.IsInRole("Receptionist"))
    {
        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@t.Id" class="btn btn-sm btn-outline-dark">
                <i class="bi bi-pencil me-1"></i> Edit
            </a>
            @if (t.ActiveMembership is null)
            {
                <a asp-controller="Memberships" asp-action="Assign" asp-route-traineeId="@t.Id"
                   class="btn btn-sm btn-dark">
                    <i class="bi bi-plus-lg me-1"></i> Assign Membership
                </a>
            }
        </div>
    }
</div>

<div class="row g-4">

    <!-- Profile -->
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <h6 class="fw-semibold text-uppercase text-muted small mb-3">Profile</h6>
                <dl class="row small mb-0">
                    <dt class="col-5 text-muted">Email</dt>
                    <dd class="col-7">@t.Email</dd>

                    <dt class="col-5 text-muted">Phone</dt>
                    <dd class="col-7">@t.Phone</dd>

                    <dt class="col-5 text-muted">Date of Birth</dt>
                    <dd class="col-7">@t.DateOfBirth.ToString("dd MMM yyyy") (@t.Age yrs)</dd>

                    <dt class="col-5 text-muted">Gender</dt>
                    <dd class="col-7">@t.Gender</dd>

                    <dt class="col-5 text-muted">Joined</dt>
                    <dd class="col-7">@t.JoinDate.ToString("dd MMM yyyy")</dd>

                    @if (t.HeightCm.HasValue)
                    {
                        <dt class="col-5 text-muted">Height</dt>
                        <dd class="col-7">@t.HeightCm cm</dd>
                    }
                    @if (t.WeightKg.HasValue)
                    {
                        <dt class="col-5 text-muted">Weight</dt>
                        <dd class="col-7">@t.WeightKg kg</dd>
                    }
                    @if (t.Bmi.HasValue)
                    {
                        <dt class="col-5 text-muted">BMI</dt>
                        <dd class="col-7">@t.Bmi.Value.ToString("F1") — @t.BmiCategory</dd>
                    }

                    @if (!string.IsNullOrEmpty(t.AssignedTrainerName))
                    {
                        <dt class="col-5 text-muted">Trainer</dt>
                        <dd class="col-7 fw-semibold">@t.AssignedTrainerName</dd>
                    }
                </dl>
            </div>
        </div>
    </div>

    <!-- Membership -->
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <h6 class="fw-semibold text-uppercase text-muted small mb-3">Membership</h6>

                @if (t.ActiveMembership is not null)
                {
                    var m = t.ActiveMembership;
                    <dl class="row small mb-3">
                        <dt class="col-5 text-muted">Plan</dt>
                        <dd class="col-7 fw-semibold">@m.PlanName</dd>

                        <dt class="col-5 text-muted">Status</dt>
                        <dd class="col-7">
                            <span class="badge @Model.MembershipStatusBadge">
                                @Model.MembershipStatusText
                            </span>
                        </dd>

                        <dt class="col-5 text-muted">Start</dt>
                        <dd class="col-7">@m.StartDate.ToString("dd MMM yyyy")</dd>

                        <dt class="col-5 text-muted">Expires</dt>
                        <dd class="col-7">@m.EndDate.ToString("dd MMM yyyy")</dd>

                        <dt class="col-5 text-muted">Paid</dt>
                        <dd class="col-7">@m.AmountPaid.ToString("C") / @m.TotalAmount.ToString("C")</dd>

                        @if (m.RemainingBalance > 0)
                        {
                            <dt class="col-5 text-muted">Balance Due</dt>
                            <dd class="col-7 text-danger fw-semibold">@m.RemainingBalance.ToString("C")</dd>
                        }
                    </dl>

                    @if (User.IsInRole("Admin") || User.IsInRole("Receptionist"))
                    {
                        <div class="d-flex flex-column gap-2">
                            @if (m.RemainingBalance > 0)
                            {
                                <a asp-controller="Payments" asp-action="Record"
                                   asp-route-traineeId="@t.Id"
                                   class="btn btn-sm btn-success">
                                    <i class="bi bi-cash me-1"></i> Record Payment
                                </a>
                            }
                            @if (m.Status == GymManagement.Domain.Enums.MembershipStatus.Active)
                            {
                                <a asp-controller="Memberships" asp-action="Freeze"
                                   asp-route-traineeId="@t.Id"
                                   class="btn btn-sm btn-outline-info">
                                    <i class="bi bi-snow me-1"></i> Freeze
                                </a>
                            }
                        </div>
                    }
                }
                else
                {
                    <div class="text-center py-4 text-muted">
                        <i class="bi bi-card-text fs-2 d-block mb-2"></i>
                        No active membership
                    </div>
                    @if (User.IsInRole("Admin") || User.IsInRole("Receptionist"))
                    {
                        <a asp-controller="Memberships" asp-action="Assign"
                           asp-route-traineeId="@t.Id"
                           class="btn btn-sm btn-dark w-100 mt-2">
                            Assign Membership
                        </a>
                    }
                }
            </div>
        </div>
    </div>

    <!-- Quick actions -->
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <h6 class="fw-semibold text-uppercase text-muted small mb-3">Attendance</h6>

                @if (t.LastCheckIn.HasValue)
                {
                    <p class="small text-muted">
                        Last check-in: <strong>@t.LastCheckIn.Value.ToString("dd MMM, HH:mm")</strong>
                    </p>
                }

                @if ((User.IsInRole("Admin") || User.IsInRole("Receptionist") || User.IsInRole("Trainer"))
                                && t.ActiveMembership?.Status == GymManagement.Domain.Enums.MembershipStatus.Active)
                {
                    <form asp-controller="Attendance" asp-action="CheckIn" method="post" class="mb-2">
                        <input type="hidden" name="traineeId" value="@t.Id" />
                        <input type="hidden" name="method" value="Manual" />
                        <button type="submit" class="btn btn-sm btn-success w-100">
                            <i class="bi bi-box-arrow-in-right me-1"></i> Check In
                        </button>
                    </form>
                    <form asp-controller="Attendance" asp-action="CheckOut" method="post">
                        <input type="hidden" name="traineeId" value="@t.Id" />
                        <button type="submit" class="btn btn-sm btn-outline-secondary w-100">
                            <i class="bi bi-box-arrow-right me-1"></i> Check Out
                        </button>
                    </form>
                }

                @if (!string.IsNullOrEmpty(t.MedicalNotes))
                {
                    <hr />
                    <h6 class="fw-semibold text-uppercase text-muted small mb-2">Medical Notes</h6>
                    <p class="small text-muted mb-0">@t.MedicalNotes</p>
                }

                @if (User.IsInRole("Admin"))
                {
                    <hr />
                    <div class="d-flex gap-2">
                        <form asp-action="Delete" method="post" class="flex-grow-1"
                              onsubmit="return confirm('Delete this trainee?')">
                            <input type="hidden" name="id" value="@t.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-danger w-100">
                                <i class="bi bi-trash me-1"></i> Delete
                            </button>
                        </form>
                        <form asp-action="Anonymise" method="post" class="flex-grow-1"
                              onsubmit="return confirm('Anonymise all personal data? This cannot be undone.')">
                            <input type="hidden" name="id" value="@t.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-warning w-100">
                                <i class="bi bi-shield-x me-1"></i> GDPR
                            </button>
                        </form>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
