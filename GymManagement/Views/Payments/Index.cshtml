@using GymManagement.Domain.Results
@using GymManagement.Domain.Enums
@model PagedResult<GymManagement.Application.Common.DTOs.PaymentDto>
@{
    ViewData["Title"] = "Payment History";
    var currentSearch = ViewBag.CurrentSearch as string;
    var currentMethod = ViewBag.CurrentMethod as PaymentMethod?;
    var currentStatus = ViewBag.CurrentStatus as PaymentStatus?;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0">Payment History</h4>
        <p class="text-muted small mb-0">Track and manage all gym payments</p>
    </div>
    <div class="d-flex gap-2">
        <form method="get" class="d-flex gap-2 align-items-center">
            <input type="text" name="searchTerm" value="@currentSearch" class="form-control form-control-sm" placeholder="Search trainee or email..." style="width: 250px;" />
            
            <select name="status" class="form-select form-select-sm" onchange="this.form.submit()">
                <option value="">All Statuses</option>
                @foreach (var status in Enum.GetValues<PaymentStatus>())
                {
                    <option value="@status" selected="@(currentStatus == status)">@status</option>
                }
            </select>

            <select name="method" class="form-select form-select-sm" onchange="this.form.submit()">
                <option value="">All Methods</option>
                @foreach (var method in Enum.GetValues<PaymentMethod>())
                {
                    <option value="@method" selected="@(currentMethod == method)">@method</option>
                }
            </select>
            
            <button type="submit" class="btn btn-sm btn-primary">
                <i class="bi bi-search"></i>
            </button>

            @if (currentMethod.HasValue || currentStatus.HasValue || !string.IsNullOrEmpty(currentSearch))
            {
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Clear</a>
            }
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Date</th>
                    <th>Trainee</th>
                    <th>Plan</th>
                    <th>Paid</th>
                    <th>Balance</th>
                    <th>Status</th>
                    <th class="text-end">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model.Items)
                {
                    <tr class="@(p.IsRefunded ? "table-light opacity-75" : "")">
                        <td class="small">@p.PaidAt.ToString("dd MMM yyyy")</td>
                        <td class="fw-semibold">@p.TraineeName</td>
                        <td class="text-muted small">@p.PlanName</td>
                        <td class="fw-bold @(p.IsRefunded ? "text-decoration-line-through text-muted" : "text-dark")">
                            @p.Amount.ToString("C")
                        </td>
                        <td class="small @(p.RemainingBalance > 0 ? "text-danger fw-bold" : "text-success")">
                            @(p.RemainingBalance > 0 ? p.RemainingBalance.ToString("C") : "Fully Paid")
                        </td>
                        <td>
                            @if (p.IsRefunded)
                            {
                                <span class="badge bg-danger">Refunded</span>
                            }
                            else if (p.Status == PaymentStatus.PartiallyPaid)
                            {
                                <span class="badge bg-warning text-dark">Partial</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Paid</span>
                            }
                        </td>
                        <td class="text-end">
                            <div class="btn-group">
                                @if (!p.IsRefunded && (p.Status == PaymentStatus.PartiallyPaid || p.RemainingBalance > 0))
                                {
                                    <a asp-action="Update" asp-route-id="@p.Id" class="btn btn-sm btn-primary">
                                        <i class="bi bi-plus-lg"></i> Pay
                                    </a>
                                }

                                @if (!p.IsRefunded && User.IsInRole("Admin"))
                                {
                                    <form asp-action="Refund" method="post" class="d-inline" onsubmit="return confirm('Refund this payment?')">
                                        <input type="hidden" name="paymentId" value="@p.Id" />
                                        <input type="hidden" name="reason" value="User requested refund" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            Refund
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-5">
                            <i class="bi bi-receipt fs-2 d-block mb-2"></i>
                            No payment records found.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.TotalPages > 1)
    {
        <div class="card-footer bg-white border-top-0 py-3">
            <nav>
                <ul class="pagination pagination-sm justify-content-center mb-0">
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.Page ? "active" : "")">
                            <a class="page-link" asp-action="Index" 
                               asp-route-page="@i" 
                               asp-route-searchTerm="@currentSearch"
                               asp-route-method="@currentMethod"
                               asp-route-status="@currentStatus">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        </div>
    }
</div>
