@model RecordPaymentViewModel
@{
    ViewData["Title"] = "Record Payment";
}

<div class="mb-4">
    <h4 class="fw-bold mb-0">Record Payment</h4>
    <p class="text-muted small">
        Trainee: <strong>@Model.TraineeName</strong> &mdash;
        Plan: <strong>@Model.PlanName</strong>
    </p>
</div>

<!-- Balance summary -->
<div class="row g-3 mb-4" style="max-width: 600px;">
    <div class="col-4">
        <div class="card border-0 bg-light text-center py-3">
            <div class="small text-muted">Total</div>
            <div class="fw-bold">@Model.TotalAmount.ToString("C")</div>
        </div>
    </div>
    <div class="col-4">
        <div class="card border-0 bg-success bg-opacity-10 text-center py-3">
            <div class="small text-muted">Paid</div>
            <div class="fw-bold text-success">@Model.AmountPaid.ToString("C")</div>
        </div>
    </div>
    <div class="col-4">
        <div class="card border-0 bg-danger bg-opacity-10 text-center py-3">
            <div class="small text-muted">Balance Due</div>
            <div class="fw-bold text-danger">@Model.RemainingBalance.ToString("C")</div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm" style="max-width: 500px;">
    <div class="card-body p-4">
        <form asp-action="Record" method="post">
            <input type="hidden" asp-for="MembershipId" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger small py-2 mb-3"></div>

            <div class="mb-3">
                <label asp-for="Amount" class="form-label fw-semibold small"></label>
                <div class="input-group">
                    <span class="input-group-text">MAD</span>
                    <input asp-for="Amount" class="form-control" />
                </div>
                <span asp-validation-for="Amount" class="text-danger small"></span>
                <div class="form-text">Max: @Model.RemainingBalance.ToString("C")</div>
            </div>

            <div class="mb-3">
                <label asp-for="Method" class="form-label fw-semibold small"></label>
                <select asp-for="Method" class="form-select"
                        asp-items="Html.GetEnumSelectList<GymManagement.Domain.Enums.PaymentMethod>()"></select>
            </div>

            <div class="mb-4">
                <label asp-for="Notes" class="form-label fw-semibold small"></label>
                <input asp-for="Notes" class="form-control" />
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success px-4">
                    <i class="bi bi-cash me-1"></i> Record Payment
                </button>
                <a asp-controller="Trainees" asp-action="Index" class="btn btn-outline-secondary">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
