@{
    ViewData["Title"] = "Error";
    var message = ViewBag.ErrorMessage as string ?? "An unexpected error occurred.";
}

<div class="d-flex align-items-center justify-content-center" style="min-height: 60vh;">
    <div class="text-center">
        <div class="display-1 fw-bold text-secondary mb-3"><i class="bi bi-exclamation-triangle-fill"></i></div>
        <h4 class="fw-bold">Something went wrong</h4>
        <p class="text-muted">@message</p>
        <a asp-controller="Dashboard" asp-action="Index" class="btn btn-dark">
            <i class="bi bi-house me-1"></i> Back to Dashboard
        </a>
    </div>
</div>
