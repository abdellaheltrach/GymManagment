<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Gym Management</title>
    <link href="~/lib/bootstrap/css/bootstrap.css" rel="stylesheet" />
    <link href="~/lib/bootstrap/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/lib/bootstrap/css/bootstrap.rtl.css" rel="stylesheet" />
    <link href="~/lib/bootstrap/css/bootstrap.rtl.min.css" rel="stylesheet" />

</head>
<body class="d-flex flex-column min-vh-100">

    @if (User.Identity?.IsAuthenticated == true)
    {
        <div class="d-flex flex-row flex-grow-1">

            <!-- Sidebar -->
            <nav class="sidebar d-flex flex-column p-3 text-white bg-dark"
                 style="min-width:220px; min-height:100vh;">
                <a class="navbar-brand text-white fw-bold fs-5 mb-4 d-block" href="/">
                    <i class="bi bi-lightning-charge-fill text-warning"></i> GymPro
                </a>

                <ul class="nav nav-pills flex-column mb-auto gap-1">

                    @* ── Dashboard — role-aware ──────────────────────────────────── *@
                    @if (User.IsInRole("Trainer"))
                    {
                        <li class="nav-item">
                            <a class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "TrainerDashboard" ? "active" : "")"
                               asp-controller="TrainerDashboard" asp-action="Index">
                                <i class="bi bi-grid-1x2-fill me-2"></i> Dashboard
                            </a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")"
                               asp-controller="Dashboard" asp-action="Index">
                                <i class="bi bi-grid-1x2-fill me-2"></i> Dashboard
                            </a>
                        </li>
                    }

                    @* ── Admin / Receptionist nav ────────────────────────────────── *@
                    @if (User.IsInRole("Admin") || User.IsInRole("Receptionist"))
                    {
                        <li class="nav-item">
                            <a class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "Trainees" ? "active" : "")"
                               asp-controller="Trainees" asp-action="Index">
                                <i class="bi bi-people-fill me-2"></i> Trainees
                            </a>
                        </li>
                    }

                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item">
                            <a class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "Trainers" ? "active" : "")"
                               asp-controller="Trainers" asp-action="Index">
                                <i class="bi bi-person-badge-fill me-2"></i> Trainers
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "MembershipPlans" ? "active" : "")"
                               asp-controller="MembershipPlans" asp-action="Index">
                                <i class="bi bi-card-checklist me-2"></i> Plans
                            </a>
                        </li>
                    }

                    @if (User.IsInRole("Admin") || User.IsInRole("Receptionist"))
                    {
                        <li class="nav-item">
                            <a class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "Payments" ? "active" : "")"
                               asp-controller="Payments" asp-action="Index">
                                <i class="bi bi-cash-coin me-2"></i> Payments
                            </a>
                        </li>
                    }

                    @* ── Trainer-only nav ────────────────────────────────────────── *@
                    @if (User.IsInRole("Trainer"))
                    {
                        <li class="nav-item">
                            <a class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "TrainerTrainees" ? "active" : "")"
                               asp-controller="TrainerTrainees" asp-action="Index">
                                <i class="bi bi-people-fill me-2"></i> My Trainees
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "TrainerPrograms" ? "active" : "")"
                               asp-controller="TrainerPrograms" asp-action="Index">
                                <i class="bi bi-journal-text me-2"></i> Programs
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "TrainerProgress" ? "active" : "")"
                               asp-controller="TrainerProgress" asp-action="Index">
                                <i class="bi bi-graph-up-arrow me-2"></i> Progress
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "TrainerProfile" ? "active" : "")"
                               asp-controller="TrainerProfile" asp-action="Index">
                                <i class="bi bi-person-circle me-2"></i> My Profile
                            </a>
                        </li>
                    }

                    @* ── Admin-only jobs ─────────────────────────────────────────── *@
                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item">
                            <a class="nav-link text-white" href="/hangfire">
                                <i class="bi bi-gear-fill me-2"></i> Jobs
                            </a>
                        </li>
                    }
                </ul>

                <hr class="text-secondary" />
                <div class="dropdown">
                    <a href="#" class="d-flex align-items-center text-white text-decoration-none dropdown-toggle"
                       data-bs-toggle="dropdown">
                        <i class="bi bi-person-circle me-2 fs-5"></i>
                        <span class="small">@User.Identity!.Name</span>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-dark text-small shadow">
                        <li>
                            <form asp-controller="Account" asp-action="Logout" method="post">
                                <button type="submit" class="dropdown-item">
                                    <i class="bi bi-box-arrow-right me-2"></i> Logout
                                </button>
                            </form>
                        </li>
                    </ul>
                </div>
            </nav>

            <!-- Main content -->
            <main class="flex-grow-1 p-4 bg-light">
                <!-- Alert banners -->
                @if (TempData["Success"] is string success)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="bi bi-check-circle-fill me-2"></i>@success
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @if (TempData["Error"] is string error)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>@error
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                @RenderBody()
            </main>
        </div>
    }
    else
    {
        <main class="flex-grow-1">
            @RenderBody()
        </main>
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>