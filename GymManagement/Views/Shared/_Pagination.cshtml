@model PaginationViewModel

@if (Model.TotalPages > 1)
{
    <nav class="mt-3" aria-label="Page navigation">
        <ul class="pagination pagination-sm justify-content-center mb-0">

            @* Previous *@
            <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                <a class="page-link"
                   asp-controller="@Model.ControllerName"
                   asp-action="@Model.ActionName"
                   asp-route-page="@(Model.CurrentPage - 1)"
                   asp-route-search="@Model.SearchTerm">
                    <i class="bi bi-chevron-left"></i>
                </a>
            </li>

            @* Page numbers — sliding window of 7 around current page *@
            @{
                int start = Math.Max(1, Model.CurrentPage - 3);
                int end = Math.Min(Model.TotalPages, start + 6);
                start = Math.Max(1, end - 6);
            }

            @if (start > 1)
            {
                <li class="page-item">
                    <a class="page-link"
                       asp-controller="@Model.ControllerName"
                       asp-action="@Model.ActionName"
                       asp-route-page="1"
                       asp-route-search="@Model.SearchTerm">1</a>
                </li>
                @if (start > 2)
                {
                    <li class="page-item disabled">
                        <span class="page-link">…</span>
                    </li>
                }
            }

            @for (int p = start; p <= end; p++)
            {
                <li class="page-item @(p == Model.CurrentPage ? "active" : "")">
                    <a class="page-link"
                       asp-controller="@Model.ControllerName"
                       asp-action="@Model.ActionName"
                       asp-route-page="@p"
                       asp-route-search="@Model.SearchTerm">@p</a>
                </li>
            }

            @if (end < Model.TotalPages)
            {
                @if (end < Model.TotalPages - 1)
                {
                    <li class="page-item disabled">
                        <span class="page-link">…</span>
                    </li>
                }
                <li class="page-item">
                    <a class="page-link"
                       asp-controller="@Model.ControllerName"
                       asp-action="@Model.ActionName"
                       asp-route-page="@Model.TotalPages"
                       asp-route-search="@Model.SearchTerm">@Model.TotalPages</a>
                </li>
            }

            @* Next *@
            <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                <a class="page-link"
                   asp-controller="@Model.ControllerName"
                   asp-action="@Model.ActionName"
                   asp-route-page="@(Model.CurrentPage + 1)"
                   asp-route-search="@Model.SearchTerm">
                    <i class="bi bi-chevron-right"></i>
                </a>
            </li>

        </ul>
    </nav>
}
