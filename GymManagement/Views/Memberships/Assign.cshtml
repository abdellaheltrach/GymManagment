@model AssignMembershipViewModel
@{
    ViewData["Title"] = "Assign Membership";
}

<div class="mb-4">
    <a asp-controller="Trainees" asp-action="Details" asp-route-id="@Model.TraineeId"
       class="text-muted small text-decoration-none">
        <i class="bi bi-arrow-left me-1"></i> Back to @Model.TraineeName
    </a>
    <h4 class="fw-bold mt-1 mb-0">Assign Membership</h4>
    <p class="text-muted small">Trainee: <strong>@Model.TraineeName</strong></p>
</div>

<div class="card border-0 shadow-sm" style="max-width: 600px;">
    <div class="card-body p-4">
        <form asp-action="Assign" method="post">
            <input type="hidden" asp-for="TraineeId" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger small py-2 mb-3"></div>

            <div class="mb-3">
                <label asp-for="PlanId" class="form-label fw-semibold small"></label>
                <select asp-for="PlanId" class="form-select" id="planSelect">
                    <option value="">— Select a plan —</option>
                    @foreach (var plan in Model.AvailablePlans)
                    {
                        <option value="@plan.Id"
                                data-price="@plan.Price"
                                data-duration="@plan.DurationDays"
                                data-freeze="@plan.MaxFreezeDays">
                            @plan.Name — @plan.Price.ToString("C") (@plan.DurationDays days)
                        </option>
                    }
                </select>
                <span asp-validation-for="PlanId" class="text-danger small"></span>
            </div>

            <!-- Plan summary card (populated via JS) -->
            <div id="planSummary" class="alert alert-light border small mb-3 d-none">
                <strong id="planSummaryName"></strong><br />
                Price: <span id="planSummaryPrice"></span> &nbsp;|&nbsp;
                Duration: <span id="planSummaryDuration"></span> days &nbsp;|&nbsp;
                Max freeze: <span id="planSummaryFreeze"></span> days
            </div>

            <div class="mb-3">
                <label asp-for="StartDate" class="form-label fw-semibold small"></label>
                <input asp-for="StartDate" class="form-control" type="date" />
                <span asp-validation-for="StartDate" class="text-danger small"></span>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label asp-for="InitialPaymentAmount" class="form-label fw-semibold small">
                        Initial Payment
                    </label>
                    <div class="input-group">
                        <span class="input-group-text">MAD</span>
                        <input asp-for="InitialPaymentAmount" class="form-control" />
                    </div>
                    <span asp-validation-for="InitialPaymentAmount" class="text-danger small"></span>
                    <div class="form-text">Leave 0 to set as Pending Payment.</div>
                </div>
                <div class="col-md-6">
                    <label asp-for="PaymentMethod" class="form-label fw-semibold small"></label>
                    <select asp-for="PaymentMethod" class="form-select"
                            asp-items="Html.GetEnumSelectList<GymManagement.Domain.Enums.PaymentMethod>()"></select>
                </div>
            </div>

            <div class="mb-4">
                <label asp-for="Notes" class="form-label fw-semibold small"></label>
                <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-dark px-4">
                    <i class="bi bi-check-lg me-1"></i> Assign Membership
                </button>
                <a asp-controller="Trainees" asp-action="Details" asp-route-id="@Model.TraineeId"
                   class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('planSelect').addEventListener('change', function() {
            const opt = this.options[this.selectedIndex];
            const summary = document.getElementById('planSummary');
            if (!opt.value) { summary.classList.add('d-none'); return; }
            document.getElementById('planSummaryName').textContent = opt.text;
            document.getElementById('planSummaryPrice').textContent = 'MAD ' + opt.dataset.price;
            document.getElementById('planSummaryDuration').textContent = opt.dataset.duration;
            document.getElementById('planSummaryFreeze').textContent = opt.dataset.freeze;
            summary.classList.remove('d-none');
            // Pre-fill payment amount with plan price
            document.querySelector('[name="InitialPaymentAmount"]').value = opt.dataset.price;
        });
    </script>
    <partial name="_ValidationScriptsPartial" />
}
