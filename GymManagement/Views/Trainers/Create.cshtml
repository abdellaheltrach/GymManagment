@model CreateTrainerViewModel
@{
    ViewData["Title"] = "Register Trainer";
}

<div class="mb-4">
    <a asp-action="Index" class="text-decoration-none text-muted small">
        <i class="bi bi-arrow-left"></i> Back to Trainers
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-10">
        <div class="card border-0 shadow-sm p-4 p-md-5">
            <h4 class="fw-bold mb-4">Register New Trainer</h4>

            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4"></div>

                <div class="row g-4">
                    <!-- Personal Info Section -->
                    <div class="col-12">
                        <h6 class="text-uppercase text-muted fw-bold small border-bottom pb-2">Personal Information</h6>
                    </div>
                    
                    <div class="col-md-6">
                        <label asp-for="FirstName" class="form-label small fw-semibold text-muted"></label>
                        <input asp-for="FirstName" class="form-control bg-light border-0" placeholder="e.g. John" />
                        <span asp-validation-for="FirstName" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="LastName" class="form-label small fw-semibold text-muted"></label>
                        <input asp-for="LastName" class="form-control bg-light border-0" placeholder="e.g. Smith" />
                        <span asp-validation-for="LastName" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Email" class="form-label small fw-semibold text-muted"></label>
                        <input asp-for="Email" class="form-control bg-light border-0" placeholder="john.smith@gym.com" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Phone" class="form-label small fw-semibold text-muted"></label>
                        <input asp-for="Phone" class="form-control bg-light border-0" placeholder="+123 456 789" />
                        <span asp-validation-for="Phone" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="DateOfBirth" class="form-label small fw-semibold text-muted"></label>
                        <input asp-for="DateOfBirth" class="form-control bg-light border-0" />
                        <span asp-validation-for="DateOfBirth" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Password" class="form-label small fw-semibold text-muted"></label>
                        <input asp-for="Password" class="form-control bg-light border-0" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <!-- Professional Section -->
                    <div class="col-12 mt-5">
                        <h6 class="text-uppercase text-muted fw-bold small border-bottom pb-2">Professional Details</h6>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Specialization" class="form-label small fw-semibold text-muted"></label>
                        <select asp-for="Specialization" class="form-select bg-light border-0" asp-items="Html.GetEnumSelectList<GymManagement.Domain.Enums.TrainerSpecialization>()">
                            <option value="">Select Specialization</option>
                        </select>
                        <span asp-validation-for="Specialization" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="YearsOfExperience" class="form-label small fw-semibold text-muted"></label>
                        <input asp-for="YearsOfExperience" class="form-control bg-light border-0" />
                        <span asp-validation-for="YearsOfExperience" class="text-danger small"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="Bio" class="form-label small fw-semibold text-muted"></label>
                        <textarea asp-for="Bio" class="form-control bg-light border-0" rows="3" placeholder="Brief professional background…"></textarea>
                        <span asp-validation-for="Bio" class="text-danger small"></span>
                    </div>

                    <!-- Financial Section -->
                    <div class="col-12 mt-5">
                        <h6 class="text-uppercase text-muted fw-bold small border-bottom pb-2">Contract & Salary</h6>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="SalaryType" class="form-label small fw-semibold text-muted"></label>
                        <select asp-for="SalaryType" class="form-select bg-light border-0" asp-items="Html.GetEnumSelectList<GymManagement.Domain.Enums.SalaryType>()"></select>
                        <span asp-validation-for="SalaryType" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="BaseSalary" class="form-label small fw-semibold text-muted"></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-0">$</span>
                            <input asp-for="BaseSalary" class="form-control bg-light border-0" />
                        </div>
                        <span asp-validation-for="BaseSalary" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="CommissionPerTrainee" class="form-label small fw-semibold text-muted"></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-0">$</span>
                            <input asp-for="CommissionPerTrainee" class="form-control bg-light border-0" />
                        </div>
                        <span asp-validation-for="CommissionPerTrainee" class="text-danger small"></span>
                    </div>

                    <div class="col-12 mt-5 pt-3">
                        <button type="submit" class="btn btn-dark px-5">
                            <i class="bi bi-person-plus me-2"></i> Create Trainer Account
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
