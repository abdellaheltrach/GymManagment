@model TrainerListViewModel
@{
    ViewData["Title"] = "Trainers";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">Trainers</h4>
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-dark btn-sm">
            <i class="bi bi-plus-lg me-1"></i> Register Trainer
        </a>
    }
</div>

<!-- Search + Filter -->
<form asp-action="Index" method="get" class="row g-2 mb-4">
    <div class="col-md-5">
        <input type="text" name="search" value="@Model.Pagination.SearchTerm"
               class="form-control" placeholder="Search by name or email…" />
    </div>
    <div class="col-md-3">
        <select name="specialization" class="form-select">
            <option value="">All specializations</option>
            @foreach (var s in Enum.GetValues<GymManagement.Domain.Enums.TrainerSpecialization>())
            {
                <option value="@s">@s</option>
            }
        </select>
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-dark">
            <i class="bi bi-search"></i> Search
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
    </div>
</form>

<!-- Table -->
<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Specialization</th>
                    <th>Experience</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var t in Model.Trainers)
                {
                    <tr>
                        <td>
                            <div class="d-flex align-items-center">
                                <div class="avatar-circle-sm bg-dark text-white me-2">
                                    @t.FirstName[0]@t.LastName[0]
                                </div>
                                <span class="fw-semibold">@t.FullName</span>
                            </div>
                        </td>
                        <td class="text-muted small">@t.Email</td>
                        <td class="text-muted small">@t.Phone</td>
                        <td>
                            <span class="badge bg-secondary">@t.Specialization</span>
                        </td>
                        <td class="small">@t.YearsOfExperience Years</td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@t.Id"
                               class="btn btn-sm btn-outline-dark">
                                <i class="bi bi-eye"></i> View
                            </a>
                        </td>
                    </tr>
                }
                @if (!Model.Trainers.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">
                            No trainers found.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Pagination -->
@if (Model.Pagination.TotalPages > 1)
{
    <nav class="mt-4">
        <ul class="pagination pagination-sm justify-content-center">
            <li class="page-item @(!Model.Pagination.HasPreviousPage ? "disabled" : "")">
                <a class="page-link"
                   asp-action="Index"
                   asp-route-page="@(Model.Pagination.CurrentPage - 1)"
                   asp-route-search="@Model.Pagination.SearchTerm">Previous</a>
            </li>
            @for (int i = 1; i <= Model.Pagination.TotalPages; i++)
            {
                <li class="page-item @(i == Model.Pagination.CurrentPage ? "active" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@i"
                       asp-route-search="@Model.Pagination.SearchTerm">@i</a>
                </li>
            }
            <li class="page-item @(!Model.Pagination.HasNextPage ? "disabled" : "")">
                <a class="page-link"
                   asp-action="Index"
                   asp-route-page="@(Model.Pagination.CurrentPage + 1)"
                   asp-route-search="@Model.Pagination.SearchTerm">Next</a>
            </li>
        </ul>
    </nav>
}
