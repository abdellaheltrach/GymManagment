@model ReceptionistListViewModel
@{
    ViewData["Title"] = "Staff — Receptionists";
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div>
        <h4 class="fw-bold mb-0">Receptionists</h4>
        <p class="text-muted small mb-0">@Model.Pagination.TotalCount total</p>
    </div>
    <a asp-action="Create" class="btn btn-dark btn-sm">
        <i class="bi bi-person-plus me-1"></i> Add Receptionist
    </a>
</div>

@* Search + Filter *@
<form method="get" class="row g-2 mb-4">
    <div class="col-md-5">
        <input type="text" name="search" value="@Model.SearchTerm"
               class="form-control form-control-sm"
               placeholder="Search name, email, phone..." />
    </div>
    <div class="col-md-3">
        <select name="active" class="form-select form-select-sm">
            <option value="">All Status</option>
                <option value="true" selected="@(Model.FilterActive == true)">Active</option>
                <option value="false" selected="@(Model.FilterActive == false)">Inactive</option>
        </select>
    </div>
    <div class="col-auto d-flex gap-2">
        <button class="btn btn-sm btn-outline-secondary" type="submit">Filter</button>
        <a asp-action="Receptionists" class="btn btn-sm btn-link text-muted">Clear</a>
    </div>
</form>

@if (!Model.Items.Any())
{
    <div class="text-center text-muted py-5">
        <i class="bi bi-people fs-1 d-block mb-2 opacity-25"></i>
        No receptionists found.
        <a asp-action="Create">Add the first one.</a>
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Hired</th>
                        <th class="text-center">Permissions</th>
                        <th class="text-center">Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model.Items)
                    {
                        <tr>
                            <td class="fw-semibold">@r.FullName</td>
                            <td class="small">@r.Email</td>
                            <td class="small">@r.Phone</td>
                            <td class="small">@r.HireDate.ToString("dd MMM yyyy")</td>
                            <td class="text-center">
                                <span class="badge bg-light text-dark border"
                                      title="@r.Permissions.ToString()">
                                    @r.PermCount / 9
                                </span>
                            </td>
                            <td class="text-center">
                                <span class="@r.StatusBadge small">@r.StatusLabel</span>
                            </td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@r.Id"
                                   class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@r.Id"
                                   class="btn btn-sm btn-outline-dark ms-1">
                                    <i class="bi bi-pencil"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @* Pagination using shared component *@
    @await Html.PartialAsync("_Pagination", Model.Pagination)
}