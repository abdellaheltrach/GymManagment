@model CreateReceptionistViewModel
@using GymManagement.Domain.Enums
@{
    ViewData["Title"] = "Add Receptionist";
}

<div class="mb-4">
    <a asp-action="Receptionists" class="text-muted small text-decoration-none">
        <i class="bi bi-arrow-left me-1"></i> Back to Staff
    </a>
    <h4 class="fw-bold mb-0 mt-1">Add Receptionist</h4>
</div>

<div style="max-width:860px">
    <form asp-action="Create" method="post">
        <div asp-validation-summary="All"
             class="alert alert-danger small py-2 mb-3"></div>

        @* Personal Info *@
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white fw-semibold small text-uppercase text-muted">
                Personal Information
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="FirstName" class="form-label fw-semibold small"></label>
                        <input asp-for="FirstName" class="form-control" />
                        <span asp-validation-for="FirstName" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="LastName" class="form-label fw-semibold small"></label>
                        <input asp-for="LastName" class="form-control" />
                        <span asp-validation-for="LastName" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Email" class="form-label fw-semibold small"></label>
                        <input asp-for="Email" class="form-control" type="email" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Phone" class="form-label fw-semibold small"></label>
                        <input asp-for="Phone" class="form-control" />
                        <span asp-validation-for="Phone" class="text-danger small"></span>
                    </div>
                </div>
            </div>
        </div>

        @* Password *@
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white fw-semibold small text-uppercase text-muted">
                Login Password
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="Password" class="form-label fw-semibold small"></label>
                        <input asp-for="Password" class="form-control"
                               type="password" autocomplete="new-password" />
                        <div class="form-text small">
                            Min 12 characters · uppercase · lowercase · digit · special character
                        </div>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="ConfirmPassword" class="form-label fw-semibold small"></label>
                        <input asp-for="ConfirmPassword" class="form-control"
                               type="password" autocomplete="new-password" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>
                </div>
            </div>
        </div>

        @* Permissions *@
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <span class="fw-semibold small text-uppercase text-muted">Permissions</span>
                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-sm btn-outline-secondary py-0 px-2"
                            onclick="setAll(true)">
                        All
                    </button>
                    <button type="button" class="btn btn-sm btn-outline-secondary py-0 px-2"
                            onclick="setAll(false)">
                        None
                    </button>
                    <button type="button" class="btn btn-sm btn-outline-dark py-0 px-2"
                            onclick="setPreset()">
                        Standard Desk
                    </button>
                </div>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    @foreach (var perm in PermissionUiHelper.AllPermissions)
                    {
                        var isStandard = (ReceptionistPermission.StandardDesk & perm.Value) == perm.Value;
                        <div class="col-md-6">
                            <label class="perm-card d-flex align-items-start gap-3 border rounded p-3"
                                   style="cursor:pointer">
                                <input type="checkbox"
                                       name="SelectedPermissions"
                                       value="@((int)perm.Value)"
                                       class="form-check-input mt-1 flex-shrink-0 perm-check"
                                       @(isStandard ? "checked" : "") />
                                <div>
                                    <div class="fw-semibold small">@perm.Label</div>
                                    <div class="text-muted small">@perm.Description</div>
                                </div>
                            </label>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-dark">
                <i class="bi bi-person-plus me-1"></i> Create Receptionist
            </button>
            <a asp-action="Receptionists" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</div>

<style>
    .perm-card:has(input:checked) {
        border-color: #0d6efd !important;
        background-color: #eff6ff;
    }
    .perm-card:hover { background-color: #f9fafb; }
</style>

@section Scripts {
    <script>
        const standardBits = @((int)ReceptionistPermission.StandardDesk);

        function setAll(checked) {
            document.querySelectorAll('.perm-check')
                .forEach(cb => cb.checked = checked);
        }

        function setPreset() {
            document.querySelectorAll('.perm-check').forEach(cb => {
                const bit = parseInt(cb.value);
                cb.checked = (standardBits & bit) === bit;
            });
        }
    </script>
}
